<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexus.system.infrastructure.mapper.SysUserMapper">

    <select id="selectUserList" parameterType="com.nexus.system.domain.model.SysUser" resultMap="SysUserResult">
        select u.id, u.tenant_id, u.main_shop_id, u.main_org_id, u.username, u.real_name, u.avatar_url, u.status, u.del_flag, u.create_by, u.create_time, u.update_by, u.update_time, o.org_name
        from sys_user u
        left join sys_org o on u.main_org_id = o.id and o.del_flag = 0
        where u.del_flag = 0
          AND u.tenant_id = #{user.tenantId}
        <if test="user.username != null and user.username != ''">
            AND u.username like concat('%', #{user.username}, '%')
        </if>
        <if test="user.status != null">
            AND u.status = #{user.status}
        </if>
        <if test="user.mainOrgId != null">
            AND u.main_org_id = #{user.mainOrgId}
        </if>
    </select>

    <resultMap id="SysUserResult" type="com.nexus.system.domain.model.SysUser">
        <id property="id" column="id" />
        <result property="tenantId" column="tenant_id" />
        <result property="mainShopId" column="main_shop_id" />
        <result property="mainOrgId" column="main_org_id" />
        <result property="username" column="username" />
        <result property="realName" column="real_name" />
        <result property="avatarUrl" column="avatar_url" />
        <result property="status" column="status" />
        <result property="delFlag" column="del_flag" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

</mapper>
